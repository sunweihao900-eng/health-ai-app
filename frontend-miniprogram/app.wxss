/* 全局样式 */
page {
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  color: #212529;
  background-color: #f8f9fa;
  box-sizing: border-box;
}

/* 统一按钮重置 */
button {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  border-radius: 0;
  line-height: normal;
}

button::after {
  border: none;
}
