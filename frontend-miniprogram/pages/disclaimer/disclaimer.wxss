.page { background: #fff; min-height: 100vh; }
.header { padding: 36rpx 32rpx 24rpx; background: linear-gradient(135deg, #0a7c5f, #064e3b); display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.header-logo { font-size: 64rpx; }
.header-title { font-size: 34rpx; font-weight: 800; color: #fff; }
.header-sub { font-size: 24rpx; color: rgba(255,255,255,0.7); }
.content { padding: 24rpx 32rpx 0; }
.section { margin-bottom: 28rpx; background: #f8fafc; border-radius: 14rpx; padding: 20rpx 24rpx; }
.section-title { font-size: 28rpx; font-weight: 700; color: #0a7c5f; margin-bottom: 12rpx; }
.section-body { font-size: 26rpx; color: #445; line-height: 1.7; }
.emergency-section { background: #fff5f5; border-left: 6rpx solid #ef4444; }
.emergency-section .section-title { color: #ef4444; }
.emergency-text { font-size: 28rpx; font-weight: 600; color: #dc3545; margin-bottom: 10rpx; line-height: 1.6; }
.bottom-marker { text-align: center; padding: 32rpx 0 48rpx; font-size: 24rpx; color: #adb5bd; }
.footer { position: sticky; bottom: 0; padding: 16rpx 32rpx 48rpx; border-top: 1rpx solid #e2e8f0; background: #fff; }
.read-tip { text-align: center; font-size: 24rpx; color: #8fa0b3; margin-bottom: 12rpx; }
.agree-btn { padding: 28rpx; border-radius: 16rpx; text-align: center; font-size: 30rpx; font-weight: 700; }
.agree-btn.active { background: linear-gradient(135deg, #0a7c5f, #064e3b); color: #fff; }
.agree-btn.inactive { background: #cbd5e1; color: #fff; }
