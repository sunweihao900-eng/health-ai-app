<view class="container">

  <!-- 顶部合规横幅 -->
  <view class="banner">
    <view class="banner-left">
      <view class="aigc-tag">🤖 AIGC</view>
      <text class="banner-text">内容仅供健康科普参考，不构成医疗诊断</text>
    </view>
    <view class="emergency-btn" bindtap="callEmergency">
      <text>📞 120</text>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view class="msg-list" scroll-y="true" scroll-into-view="{{scrollId}}" scroll-with-animation="true" enhanced="true">

    <block wx:for="{{messages}}" wx:key="id">

      <!-- 用户消息 -->
      <view wx:if="{{item.role === 'user'}}" class="msg-row user-row">
        <view class="user-bubble">
          <text class="bubble-text">{{item.content}}</text>
        </view>
      </view>

      <!-- AI消息 -->
      <view wx:elif="{{item.role === 'assistant'}}" class="msg-row ai-row">
        <view class="ai-avatar">🏥</view>
        <view class="ai-content-wrap">
          <!-- 加载骨架 -->
          <view wx:if="{{item.isStreaming && item.content.length === 0}}" class="bubble ai-bubble">
            <view class="skeleton-line" style="width:80%"></view>
            <view class="skeleton-line" style="width:60%"></view>
            <view class="skeleton-line" style="width:70%"></view>
          </view>

          <!-- 内容气泡（流式时显示纯文本，完成后显示六段式） -->
          <view wx:elif="{{item.sections && item.sections.length > 0}}" class="bubble ai-bubble sections-bubble">
            <block wx:for="{{item.sections}}" wx:key="key" wx:for-item="sec">
              <view class="section-card" style="border-left-color:{{sec.color}};background:{{sec.bg}}">
                <view class="section-title" style="color:{{sec.color}}">{{sec.title}}</view>
                <text class="section-body">{{sec.body}}</text>
              </view>
            </block>
          </view>
          <view wx:else class="bubble ai-bubble">
            <text class="bubble-text">{{item.content}}</text>
            <text wx:if="{{item.isStreaming}}" class="cursor"> ▌</text>
          </view>

          <!-- AIGC底部标识 -->
          <view wx:if="{{!item.isStreaming}}" class="aigc-mini">
            <text>🤖 AI生成内容 · 仅供科普参考 · 不能替代医生</text>
          </view>
        </view>
      </view>

    </block>

    <!-- 追问建议 -->
    <view wx:if="{{followUps.length > 0}}" class="followup-wrap">
      <text class="followup-label">💬 您可能还想了解：</text>
      <scroll-view scroll-x="true" class="followup-scroll">
        <view wx:for="{{followUps}}" wx:key="*this" class="followup-chip" bindtap="sendFollowUp" data-q="{{item}}">
          <text>{{item}}</text>
        </view>
      </scroll-view>
    </view>

    <view id="scroll-bottom" />
  </scroll-view>

  <!-- 快捷卡片 -->
  <scroll-view class="quick-cards" scroll-x="true">
    <view wx:for="{{quickCards}}" wx:key="text" class="qcard {{item.redzone ? 'qcard-red' : 'qcard-green'}}" bindtap="sendQuick" data-text="{{item.text}}">
      <text class="qcard-icon">{{item.icon}}</text>
      <text class="qcard-text">{{item.text}}</text>
      <text wx:if="{{item.redzone}}" class="qcard-badge">拦截</text>
    </view>
  </scroll-view>

  <!-- 输入区 -->
  <view class="input-area">
    <textarea
      class="input-box {{focused ? 'focused' : ''}}"
      value="{{inputText}}"
      bindinput="onInput"
      bindfocus="onFocus"
      bindblur="onBlur"
      placeholder="{{isStreaming ? 'AI回复中…' : '请输入健康咨询问题…'}}"
      disabled="{{isStreaming}}"
      auto-height
      maxlength="500"
      cursor-spacing="20"
      adjust-position="true"
    />
    <view class="send-btn {{canSend ? '' : 'disabled'}}" bindtap="handleSend">
      <text wx:if="{{isStreaming}}">⏳</text>
      <text wx:else>↑</text>
    </view>
  </view>

  <view class="input-tip">本助手不能替代医生诊断 · 如有不适请就医</view>

</view>
