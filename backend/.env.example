# ── API 密钥 ────────────────────────────────────────────────────
# OpenRouter key (sk-or-v1-...) 或 Anthropic key (sk-ant-...)
ANTHROPIC_API_KEY=your-api-key-here

# ── JWT 安全 ────────────────────────────────────────────────────
# 生产环境请替换为随机长字符串，可用: openssl rand -hex 32
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production

# ── 调试模式 ────────────────────────────────────────────────────
DEBUG=false

# ── RAG（知识库检索）────────────────────────────────────────────
# Railway/Render 免费套餐请设为 false（节省约 500MB 内存）
ENABLE_RAG=false
CHROMA_PERSIST_DIR=./chroma_db

# ── 限流 ───────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10

# ── CORS（允许的前端域名）────────────────────────────────────────
# ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=
